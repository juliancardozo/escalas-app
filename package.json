{
  "name": "escalas-improvisacion",
  "version": "1.0.0",
  "description": "Referencia de escalas para músicos de improvisación",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.escalas.improv",
    "productName": "Escalas para Improvisación",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "author": "Julian Cardozo",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1"
  }
}
